{
  "name": "linkding-cn",
  "version": "1.0.6",
  "description": "Self-hosted bookmark manager - Chinese enhanced fork of linkding",
  "main": "index.js",
  "scripts": {
    "build": "npm run build-js && npm run build-theme-light && npm run build-theme-dark",
    "build-js": "rollup -c",
    "build-theme-light": "POSTCSS_DISABLE_CACHE=true postcss -o bookmarks/static/theme-light.css bookmarks/styles/theme-light.css",
    "build-theme-dark": "POSTCSS_DISABLE_CACHE=true postcss -o bookmarks/static/theme-dark.css bookmarks/styles/theme-dark.css",
    "dev": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WooHooDai/linkding-cn.git"
  },
  "keywords": [],
  "author": "WooHooDai",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/WooHooDai/linkding-cn/issues"
  },
  "homepage": "https://github.com/WooHooDai/linkding-cn#readme",
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@hotwired/turbo": "^8.0.6",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/wasm-node": "^4.13.0",
    "approx-string-match": "^2.0.0",
    "cssnano": "^7.0.6",
    "defuddle": "^0.18.1",
    "iconify-icon": "^3.0.2",
    "lit": "^3.3.1",
    "postcss": "^8.4.45",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^14.0.0",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "web-types": "./web-types.json"
}
